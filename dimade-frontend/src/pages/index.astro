---
// Importamos los estilos globales y los componentes necesarios
import "@/styles/global.css";
import { MoveRight, Building2, HardHat, Laptop, ClipboardCheck, ArrowUpRight } from "lucide-react";
import InteractiveBento from "@/components/ui/InteractiveBento";
---

<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>Dimade SpA | Suministros Industriales y Corporativos</title>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#fdfdfd] text-slate-900 font-['Inter',sans-serif] selection:bg-primary/20">

		<!-- 1. NAVEGACIÓN ESTILO APPLE (MINIMALISTA) -->
		<nav class="fixed top-0 w-full z-50 bg-white/70 backdrop-blur-md border-b border-slate-100">
			<div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
				<!-- Logo -->
				<div class="flex items-center gap-2">
					<img src="/logo_dimade.png" alt="Dimade Logo" class="h-8 w-auto" />
				</div>
				
				<!-- Menú Central (Escritorio) -->
				<div class="hidden md:flex items-center gap-8 text-[13px] font-medium text-slate-500">
					<a href="#" class="hover:text-primary transition-colors">Inicio</a>
					<a href="#categorias" class="hover:text-primary transition-colors">Categorías</a>
					<a href="#nosotros" class="hover:text-primary transition-colors">Nosotros</a>
				</div>

				<!-- Botón de Acción -->
				<a href="/auth/login" class="bg-primary text-white px-5 py-2 rounded-full text-xs font-bold hover:opacity-90 transition-all shadow-lg shadow-primary/20">
					Cotizar Proyecto
				</a>
			</div>
		</nav>

		<main class="pt-16">
			
			<!-- 2. SECCIÓN HERO (IMPACTO VISUAL) -->
			<section class="relative overflow-hidden pt-20 pb-16 md:pt-32 md:pb-24">
				<div class="max-w-7xl mx-auto px-6 text-center">
					<!-- Etiqueta superior -->
					<div class="inline-flex items-center gap-2 bg-slate-100 px-3 py-1 rounded-full mb-6">
						<span class="relative flex h-2 w-2">
							<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
							<span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
						</span>
						<span class="text-[10px] font-bold uppercase tracking-widest text-slate-600">Suministros Corporativos 2026</span>
					</div>

					<!-- Título Principal -->
					<h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-slate-900 mb-8 leading-[1.1]">
						Toda tu cadena de <br/>
						<span class="text-primary italic">suministros</span>, resuelta.
					</h1>

					<!-- Descripción -->
					<p class="max-w-2xl mx-auto text-lg text-slate-500 mb-10 leading-relaxed">
						Desde ferretería industrial hasta equipamiento de oficina de alta gama. 
						Intermediamos, gestionamos y entregamos calidad en cada rincón de tu empresa.
					</p>

					<!-- Botones de Acción -->
					<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
						<button class="w-full sm:w-auto bg-slate-900 text-white px-8 py-4 rounded-2xl font-bold flex items-center justify-center gap-2 hover:bg-slate-800 transition-all group">
							Ver Catálogo <MoveRight class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
						</button>
						<button class="w-full sm:w-auto bg-white border border-slate-200 text-slate-600 px-8 py-4 rounded-2xl font-bold hover:bg-slate-50 transition-all">
							Hablar con un experto
						</button>
					</div>
				</div>
			</section>

			<!-- 3. SECCIÓN BENTO GRID (CATEGORÍAS INTERACTIVAS) -->
			<section id="categorias" class="max-w-7xl mx-auto px-6 py-12">
				<InteractiveBento client:load />
			</section>

			<!-- 4. SECCIÓN DE CONFIANZA -->
			<section class="py-20 border-t border-slate-100">
				<div class="max-w-7xl mx-auto px-6">
					<p class="text-center text-[10px] font-black uppercase tracking-[0.4em] text-slate-400 mb-12">Empresas que confían en nuestra gestión</p>
					<div class="flex flex-wrap justify-center items-center gap-12 md:gap-24 opacity-30 grayscale hover:grayscale-0 transition-all duration-700">
						<!-- Aquí irían los logos de tus clientes reales -->
						<span class="text-2xl font-black italic">CONSTRUCTORA X</span>
						<span class="text-2xl font-black italic">MINERA DEL SUR</span>
						<span class="text-2xl font-black italic">OFICINA CENTRAL</span>
						<span class="text-2xl font-black italic">LOGISTICA SPA</span>
					</div>
				</div>
			</section>

		</main>

		<!-- 5. PIE DE PÁGINA (FOOTER) -->
		<footer class="bg-slate-900 text-white py-20">
			<div class="max-w-7xl mx-auto px-6">
				<div class="grid grid-cols-1 md:grid-cols-4 gap-12">
					<div class="col-span-2">
						<img src="/logo_dimade.png" alt="Dimade" class="h-10 w-auto mb-6" />
						<p class="text-slate-400 max-w-sm text-sm leading-relaxed">
							Especialistas en intermediación estratégica de suministros para empresas. Optimizamos tu tiempo, reducimos tus costos.
						</p>
					</div>
					<div>
						<h4 class="font-bold mb-6 text-sm">Contacto</h4>
						<ul class="text-slate-400 text-sm space-y-3">
							<li>📧 ventas@dimade.cl</li>
							<li>📍 Santiago, Chile</li>
							<li>📞 +56 9 1234 5678</li>
						</ul>
					</div>
					<div>
						<h4 class="font-bold mb-6 text-sm">Sistema</h4>
						<ul class="text-slate-400 text-sm space-y-3">
							<li><a href="/auth/login" class="hover:text-white transition-colors">Acceso Colaboradores</a></li>
							<li><a href="#" class="hover:text-white transition-colors">Términos de Servicio</a></li>
						</ul>
					</div>
				</div>
				<div class="mt-20 pt-8 border-t border-white/5 text-center text-slate-500 text-[10px] uppercase tracking-widest">
					&copy; 2026 Dimade SpA. Todos los derechos reservados.
				</div>
			</div>
		</footer>

	</body>
</html>
