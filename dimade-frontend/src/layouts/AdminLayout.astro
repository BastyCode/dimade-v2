---
import "@/styles/global.css";
import { Menu, X, LogOut, Users, ChevronDown, LayoutDashboard, ShoppingCart, Truck, Package, Settings } from "lucide-react";

interface Props {
	title: string;
}

const { title } = Astro.props;
const pathname = Astro.url.pathname;

const isActive = (path: string) => {
	if (path === '/admin') return pathname === '/admin';
	return pathname.startsWith(path);
};

// Determinar qué grupo debe estar abierto inicialmente basado en el pathname
const isVentasOpen = pathname.includes('/sales/') || pathname.includes('/crm/');
const isComprasOpen = pathname.includes('/purchases/');
const isAdminOpen = isActive('/admin') && !isVentasOpen && !isComprasOpen;

const linkClass = (path: string) => {
	const base = "flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition-all duration-200";
	const active = "bg-primary text-white shadow-md shadow-primary/20 font-bold";
	const inactive = "hover:bg-accent/50 text-muted-foreground hover:text-foreground";
	return `${base} ${isActive(path) ? active : inactive}`;
};

const subLinkClass = (path: string) => {
	const base = "flex items-center gap-2 text-xs py-2 transition-all duration-200 pl-4 border-l-2";
	const active = "text-primary font-bold border-primary bg-primary/5 -ml-[2px]";
	const inactive = "text-muted-foreground hover:text-primary hover:border-primary/30 border-transparent";
	return `${base} ${isActive(path) ? active : inactive}`;
};
---

<!doctype html>
<html lang="es" class="h-full scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Dimade V2 Admin</title>
	</head>
	<body class="bg-[#f8fafc] text-foreground antialiased min-h-screen">
		<div class="flex flex-col lg:flex-row min-h-screen relative">
			
			{/* Mobile Header */}
			<header class="lg:hidden sticky top-0 z-40 w-full border-b bg-card p-4 flex justify-between items-center h-16">
				<div class="flex items-center gap-2">
					<img src="/logo_dimade.png" alt="Dimade" class="h-8 w-auto" />
					<span class="font-bold text-sm">Admin</span>
				</div>
				<button id="menu-toggle" class="p-2 border rounded-lg hover:bg-accent transition-colors" aria-label="Menu">
					<Menu size={20} />
				</button>
			</header>

			{/* Sidebar Desktop */}
			<aside class="hidden lg:flex flex-col w-72 border-r bg-white p-6 gap-6 sticky top-0 h-screen overflow-y-auto">
				<div class="mb-4 px-2">
					<img src="/logo_dimade.png" alt="Dimade Logo" class="w-full h-auto max-w-[160px] mb-2" />
					<div class="flex items-center gap-2">
						<span class="h-1.5 w-1.5 rounded-full bg-green-500 animate-pulse"></span>
						<p class="text-[10px] text-muted-foreground uppercase tracking-[0.3em] font-black">Sistema Operativo</p>
					</div>
				</div>

				<nav class="flex-1 flex flex-col gap-2">
					{/* GRUPO 1: ADMINISTRACIÓN */}
					<div class="menu-group" data-group="admin">
						<button class="group-header flex items-center justify-between w-full px-4 py-2 text-[10px] font-black text-slate-400 uppercase tracking-widest hover:text-primary transition-colors">
							<span>Administración</span>
							<ChevronDown size={12} class="transition-transform duration-300" />
						</button>
						<div class="group-content flex flex-col gap-1 mt-1 overflow-hidden transition-all duration-300">
							<a href="/admin" class={linkClass("/admin")}>
								<LayoutDashboard size={18} /> Dashboard
							</a>
							<a href="/admin/products" class={linkClass("/admin/products")}>
								<Package size={18} /> Productos
							</a>
							<a href="/admin/categories" class={linkClass("/admin/categories")}>
								<Settings size={18} /> Categorías
							</a>
							<a href="/admin/users" class={linkClass("/admin/users")}>
								<Users size={18} /> Usuarios
							</a>
						</div>
					</div>

					{/* GRUPO 2: VENTAS (CLIENTES) */}
					<div class="menu-group mt-2" data-group="sales">
						<button class="group-header flex items-center justify-between w-full px-4 py-2 text-[10px] font-black text-slate-400 uppercase tracking-widest hover:text-primary transition-colors">
							<span>Ventas (Clientes)</span>
							<ChevronDown size={12} class="transition-transform duration-300" />
						</button>
						<div class="group-content flex flex-col gap-1 mt-1 overflow-hidden transition-all duration-300">
							<nav class="flex flex-col ml-3 border-l-2 border-slate-100">
								<a href="/admin/crm/clients" class={subLinkClass("/admin/crm/clients")}>Gestión de Clientes</a>
								<a href="/admin/sales/quotes" class={subLinkClass("/admin/sales/quotes")}>Mis Cotizaciones</a>
								<a href="/admin/sales/orders" class={subLinkClass("/admin/sales/orders")}>Órdenes Recibidas</a>
								<a href="/admin/sales/invoices" class={subLinkClass("/admin/sales/invoices")}>Facturas y Boletas</a>
							</nav>
						</div>
					</div>

					{/* GRUPO 3: COMPRAS (PROVEEDORES) */}
					<div class="menu-group mt-2" data-group="purchases">
						<button class="group-header flex items-center justify-between w-full px-4 py-2 text-[10px] font-black text-slate-400 uppercase tracking-widest hover:text-primary transition-colors">
							<span>Compras (Proveedores)</span>
							<ChevronDown size={12} class="transition-transform duration-300" />
						</button>
						<div class="group-content flex flex-col gap-1 mt-1 overflow-hidden transition-all duration-300">
							<nav class="flex flex-col ml-3 border-l-2 border-slate-100">
								<a href="/admin/purchases/suppliers" class={subLinkClass("/admin/purchases/suppliers")}>Gestión Proveedores</a>
								<a href="/admin/purchases/quotes-in" class={subLinkClass("/admin/purchases/quotes-in")}>Cotizaciones Proveedores</a>
								<a href="/admin/purchases/orders" class={subLinkClass("/admin/purchases/orders")}>Mis Órdenes (OC)</a>
								<a href="/admin/purchases/invoices" class={subLinkClass("/admin/purchases/invoices")}>Facturas de Compra</a>
							</nav>
						</div>
					</div>

					<button class="logout-btn mt-auto flex items-center gap-3 px-6 py-4 rounded-2xl text-red-600 hover:bg-red-50 hover:text-red-700 text-[10px] uppercase tracking-[0.2em] font-black transition-all border border-transparent hover:border-red-100 shadow-sm">
						<LogOut size={16} strokeWidth={3} /> Cerrar Sesión
					</button>
				</nav>
			</aside>

			{/* Main Content */}
			<main class="flex-1 p-6 lg:p-10 max-w-7xl mx-auto w-full overflow-y-auto">
				<slot />
			</main>
		</div>

		<script is:inline define:vars={{ isVentasOpen, isComprasOpen, isAdminOpen }}>
			const setupCollapsibles = () => {
				const groups = document.querySelectorAll('.menu-group');
				
				groups.forEach(group => {
					const header = group.querySelector('.group-header');
					const content = group.querySelector('.group-content');
					const chevron = group.querySelector('.lucide-chevron-down');
					const groupId = group.dataset.group;

					// Estado inicial
					let isOpen = false;
					if (groupId === 'sales' && isVentasOpen) isOpen = true;
					if (groupId === 'purchases' && isComprasOpen) isOpen = true;
					if (groupId === 'admin' && isAdminOpen) isOpen = true;

					const updateUI = (open) => {
						if (open) {
							content.style.maxHeight = content.scrollHeight + 'px';
							content.style.opacity = '1';
							chevron.style.transform = 'rotate(180deg)';
						} else {
							content.style.maxHeight = '0px';
							content.style.opacity = '0';
							chevron.style.transform = 'rotate(0deg)';
						}
					};

					updateUI(isOpen);

					header.onclick = (e) => {
						e.preventDefault();
						const currentlyOpen = !content.style.maxHeight || content.style.maxHeight !== '0px';
						
						// Opcional: Cerrar los demás al abrir uno (Acordeón)
						if (!currentlyOpen) {
							groups.forEach(other => {
								if (other !== group) {
									const otherContent = other.querySelector('.group-content');
									const otherChevron = other.querySelector('.lucide-chevron-down');
									otherContent.style.maxHeight = '0px';
									otherContent.style.opacity = '0';
									otherChevron.style.transform = 'rotate(0deg)';
								}
							});
						}

						updateUI(!currentlyOpen);
					};
				});
			};

			const setupAuth = () => {
				const logoutBtns = document.querySelectorAll('.logout-btn');
				logoutBtns.forEach(btn => {
					btn.onclick = (e) => {
						e.preventDefault();
						localStorage.removeItem('dimade_token');
						localStorage.removeItem('dimade_refresh_token');
						document.cookie = "dimade_token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 UTC; SameSite=Lax";
						window.location.href = '/auth/login';
					};
				});
			};

			setupCollapsibles();
			setupAuth();

			document.addEventListener('astro:after-swap', () => {
				setupCollapsibles();
				setupAuth();
			});
		</script>
	</body>
</html>

<style is:global>
	.custom-scrollbar::-webkit-scrollbar {
		width: 4px;
	}
	.custom-scrollbar::-webkit-scrollbar-track {
		background: transparent;
	}
	.custom-scrollbar::-webkit-scrollbar-thumb {
		background: oklch(var(--muted-foreground) / 0.2);
		border-radius: 10px;
	}
	.custom-scrollbar::-webkit-scrollbar-thumb:hover {
		background: oklch(var(--muted-foreground) / 0.4);
	}
</style>
